# Copiar este archivo a .env y completar los valores reales.
# .env nunca se sube al repositorio (ver .gitignore).

# Generar una clave nueva, por ejemplo con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# En producción debe ser False.
DJANGO_DEBUG=False

# Dominios/IPs separados por coma, sin protocolo. Obligatorio si DEBUG=False.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Nivel de logging: DEBUG, INFO, WARNING, ERROR.
DJANGO_LOG_LEVEL=INFO

# Poner en False solo si aún no hay HTTPS configurado (p. ej. desarrollo con Podman sin proxy TLS).
DJANGO_SECURE_SSL_REDIRECT=True

# Cantidad de workers de gunicorn (solo aplica cuando DJANGO_DEBUG=False).
GUNICORN_WORKERS=3

# --- Base de datos (contenedor 'db', ver docker-compose.yml) ---
# Sin POSTGRES_DB definida, la app cae a SQLite local (útil para correr
# `manage.py runserver` sin levantar Podman). Con Postgres vía Compose,
# POSTGRES_HOST/POSTGRES_PORT los define el propio docker-compose.yml.
POSTGRES_DB=sistema_escolar
POSTGRES_USER=sistema_escolar
POSTGRES_PASSWORD=

# --- Puerto público ---
# Puerto del host donde Nginx queda expuesto (único punto de entrada del stack).
HTTP_PORT=8000

